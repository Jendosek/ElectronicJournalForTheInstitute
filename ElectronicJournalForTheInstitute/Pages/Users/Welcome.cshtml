@page
@model ElectronicJournalForTheInstitute.Pages.Users.Welcome
@{
    ViewData["Title"] = "Ласкаво просимо";
}

<div class="text-center mt-5">
    <h1 class="display-4">Вітаємо в Електронному Журналі!</h1>
    <p class="lead mt-4">Ви успішно вийшли з системи або ще не авторизовані.</p>
    <div class="mt-4">
        <a asp-page="/Users/Login" class="btn btn-primary btn-lg mx-2">Увійти</a>
        <a asp-page="/Users/Register" class="btn btn-outline-secondary btn-lg mx-2">Зареєструватися</a>
    </div>
</div>