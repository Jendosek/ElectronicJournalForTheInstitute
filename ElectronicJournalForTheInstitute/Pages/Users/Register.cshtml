@page
@model ElectronicJournalForTheInstitute.Pages.Users.RegisterModel
@{
    ViewData["Title"] = "Реєстрація";
}

<div class="row justify-content-center">
    <div class="col-md-4">
        <h2 class="text-center">Реєстрація</h2>
        <form method="post" class="mt-4">
            <div asp-validation-summary="All" class="text-danger"></div>
            
            <div class="mb-3">
                <label asp-for="Input.FullName" class="form-label">ПІБ</label>
                <input asp-for="Input.FullName" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">Email</label>
                <input asp-for="Input.Email" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label">Пароль</label>
                <input asp-for="Input.Password" class="form-control" />
            </div>
            
            <button type="submit" class="btn btn-primary w-100">Зареєструватися</button>
        </form>
    </div>
</div>