<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - ElectronicJournalForTheInstitute</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/ElectronicJournalForTheInstitute.styles.css" asp-append-version="true"/>
</head>
<body>
<header>
    <nav class="navbar navbar-expand-lg app-navbar">
        <div class="container">
            <a class="navbar-brand fw-semibold" asp-area="" asp-page="/Index">Електронний журнал</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/Index">Головна</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/AboutProject">Про проєкт</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/Features/Students/Index">Студенти</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/Features/Groups/Index">Групи</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/Features/Teachers/Index">Викладачі</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/Features/Subjects/Index">Предмети</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/Features/Lessons/Index">Заняття</a></li>
                    <li class="nav-item"><a class="nav-link" asp-area="" asp-page="/Features/Grades/Index">Оцінки</a></li>
                </ul>
                <ul class="navbar-nav align-items-lg-center gap-lg-2">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <span class="nav-link text-dark">
                                Привіт, @User.Identity.Name!
                                <span class="badge rounded-pill text-bg-light border ms-1">
                                    @(User.IsInRole("admin") ? "admin" : "user")
                                </span>
                            </span>
                        </li>
                        <li class="nav-item">
                            <form asp-page="/Features/Users/Logout" method="post">
                                <button type="submit" class="btn btn-outline-primary btn-sm">Вийти</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-outline-secondary btn-sm" asp-page="/Features/Users/Register">Реєстрація</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary btn-sm" asp-page="/Features/Users/Login">Вхід</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
</header>

<div class="container page-shell">
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="role-banner mb-4">
            @if (User.IsInRole("admin"))
            {
                <span>Режим адміністратора: доступне додавання, редагування та видалення записів.</span>
            }
            else
            {
                <span>Режим користувача: доступний лише перегляд даних без змін.</span>
            }
        </div>
    }

    <main role="main" class="pb-4">
        @RenderBody()
    </main>
</div>

<footer class="footer text-muted">
    <div class="container d-flex flex-column flex-md-row justify-content-between gap-2">
        <span>&copy; 2026 - ElectronicJournalForTheInstitute</span>
        <a asp-area="" asp-page="/Privacy">Privacy</a>
    </div>
</footer>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>