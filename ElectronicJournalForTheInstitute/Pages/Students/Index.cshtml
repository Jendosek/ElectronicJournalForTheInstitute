@page
@model ElectronicJournalForTheInstitute.Pages.Students.IndexModel
@{
    ViewData["Title"] = "Студенти";
    Layout = "_Layout";
}

<h1>Список студентів</h1>

<table class="table table-striped mt-4">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Ім'я</th>
            <th>Прізвище</th>
            <th>Дата народження</th>
            <th>ID Групи</th>
            <th>Дії</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var student in Model.Students)
        {
            <tr>
                <td>@student.Id</td>
                <td>@student.FirstName</td>
                <td>@student.LastName</td>
                <td>@student.DateOfBirth.ToShortDateString()</td>
                <td>@student.GroupId</td>
                <td> <a asp-page="./Details" asp-route-id="@student.Id" class="btn btn-sm btn-primary">Деталі / Редагувати</a></td>
            </tr>
        }
    </tbody>
</table>

<hr class="my-5" />

<div class="row">
    <div class="col-md-4">
        <h3>Додати нового студента</h3>
        <form method="post">
            <div class="mb-3">
                <label asp-for="NewStudent.FirstName" class="form-label">Ім'я</label>
                <input asp-for="NewStudent.FirstName" class="form-control" required />
            </div>
            <div class="mb-3">
                <label asp-for="NewStudent.LastName" class="form-label">Прізвище</label>
                <input asp-for="NewStudent.LastName" class="form-control" required />
            </div>
            <div class="mb-3">
                <label asp-for="NewStudent.DateOfBirth" class="form-label">Дата народження</label>
                <input asp-for="NewStudent.DateOfBirth" type="date" class="form-control" required />
            </div>
            
            <div class="mb-3">
                <label asp-for="NewStudent.GroupId" class="form-label">ID Групи (введіть 1)</label>
                <input asp-for="NewStudent.GroupId" type="number" class="form-control" value="1" />
            </div>
            <button type="submit" class="btn btn-success">Додати студента</button>
        </form>
    </div>
</div>